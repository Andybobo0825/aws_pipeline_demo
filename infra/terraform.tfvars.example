aws_region  = "ap-east-1"
project_name = "aws-devops-portfolio"
environment  = "dev"

# Create and authorize an AWS CodeStar connection to GitHub first, then paste the ARN here.
github_connection_arn = "arn:aws:codestar-connections:ap-east-1:123456789012:connection/00000000-0000-0000-0000-000000000000"
github_owner          = "your-github-user-or-org"
github_repo           = "aws-devops-portfolio"
github_branch         = "main"

container_port = 8080
desired_count  = 1
